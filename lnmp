#!/bin/bash
# ==========================================================
# LNMP 管理脚本
# 用法: lnmp {start|stop|restart|reload|status|vhost|ssl|info}
# ==========================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

print_info()  { echo -e "${CYAN}[信息]${NC} $1"; }
print_ok()    { echo -e "${GREEN}[完成]${NC} $1"; }
print_warn()  { echo -e "${YELLOW}[警告]${NC} $1"; }
print_error() { echo -e "${RED}[错误]${NC} $1"; }

INSTALL_INFO="/usr/local/nginx/conf/.lnmp_install_info"
VHOST_DIR="/usr/local/nginx/conf/vhost"
SSL_DIR="/usr/local/nginx/conf/ssl"
WEBROOT="/home/wwwroot"
LOGDIR="/home/wwwlogs"

get_php_fpm_service() {
    if [ -f /usr/local/nginx/conf/.php_fpm_service ]; then
        cat /usr/local/nginx/conf/.php_fpm_service
    else
        systemctl list-units --type=service --all | grep -oP 'php[\d.]+-fpm' | head -1
        if [ $? -ne 0 ]; then
            echo "php-fpm"
        fi
    fi
}

get_php_fpm_sock() {
    if [ -f /usr/local/nginx/conf/.php_fpm_sock ]; then
        cat /usr/local/nginx/conf/.php_fpm_sock
    else
        echo "/run/php-fpm/www.sock"
    fi
}

get_mariadb_service() {
    if systemctl list-units --type=service --all | grep -q mariadb; then
        echo "mariadb"
    else
        echo "mysql"
    fi
}

# ========================
# 服务管理
# ========================

do_start() {
    local fpm_svc db_svc
    fpm_svc=$(get_php_fpm_service)
    db_svc=$(get_mariadb_service)

    print_info "启动 LNMP 服务..."
    systemctl start nginx && print_ok "Nginx 已启动" || print_error "Nginx 启动失败"
    systemctl start "$fpm_svc" && print_ok "PHP-FPM 已启动" || print_error "PHP-FPM 启动失败"
    systemctl start "$db_svc" && print_ok "MariaDB 已启动" || print_error "MariaDB 启动失败"
}

do_stop() {
    local fpm_svc db_svc
    fpm_svc=$(get_php_fpm_service)
    db_svc=$(get_mariadb_service)

    print_info "停止 LNMP 服务..."
    systemctl stop nginx && print_ok "Nginx 已停止"
    systemctl stop "$fpm_svc" && print_ok "PHP-FPM 已停止"
    systemctl stop "$db_svc" && print_ok "MariaDB 已停止"
}

do_restart() {
    local fpm_svc db_svc
    fpm_svc=$(get_php_fpm_service)
    db_svc=$(get_mariadb_service)

    print_info "重启 LNMP 服务..."
    systemctl restart nginx && print_ok "Nginx 已重启" || print_error "Nginx 重启失败"
    systemctl restart "$fpm_svc" && print_ok "PHP-FPM 已重启" || print_error "PHP-FPM 重启失败"
    systemctl restart "$db_svc" && print_ok "MariaDB 已重启" || print_error "MariaDB 重启失败"
}

do_reload() {
    local fpm_svc
    fpm_svc=$(get_php_fpm_service)

    print_info "平滑重载配置..."

    nginx -t 2>/dev/null
    if [ $? -eq 0 ]; then
        systemctl reload nginx && print_ok "Nginx 配置已重载"
    else
        print_error "Nginx 配置检测失败，请检查配置文件"
        nginx -t
        return 1
    fi

    systemctl reload "$fpm_svc" 2>/dev/null && print_ok "PHP-FPM 已重载"
}

do_status() {
    local fpm_svc db_svc
    fpm_svc=$(get_php_fpm_service)
    db_svc=$(get_mariadb_service)

    echo ""
    echo -e "${BOLD}LNMP 服务状态:${NC}"
    echo ""

    for svc in nginx "$fpm_svc" "$db_svc"; do
        local status_text
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            status_text="${GREEN}运行中${NC}"
        else
            status_text="${RED}已停止${NC}"
        fi
        printf "  %-20s %b\n" "$svc" "$status_text"
    done

    echo ""

    local mem_used mem_total
    mem_used=$(free -m | awk '/Mem:/ {print $3}')
    mem_total=$(free -m | awk '/Mem:/ {print $2}')
    echo -e "  内存使用: ${mem_used}MB / ${mem_total}MB"

    local swap_used swap_total
    swap_used=$(free -m | awk '/Swap:/ {print $3}')
    swap_total=$(free -m | awk '/Swap:/ {print $2}')
    if [ "$swap_total" -gt 0 ]; then
        echo -e "  交换分区: ${swap_used}MB / ${swap_total}MB"
    fi

    echo ""
}

# ========================
# 虚拟主机管理
# ========================

vhost_add() {
    echo ""
    echo -en "${BOLD}请输入域名: ${NC}"
    read -r domain

    if [ -z "$domain" ]; then
        print_error "域名不能为空"
        return 1
    fi

    if [ -f "${VHOST_DIR}/${domain}.conf" ]; then
        print_error "虚拟主机 ${domain} 已存在"
        return 1
    fi

    local site_root="${WEBROOT}/${domain}"
    echo -en "${BOLD}站点目录 (默认 ${site_root}): ${NC}"
    read -r custom_root
    site_root="${custom_root:-$site_root}"

    mkdir -p "$site_root"
    chown -R www:www "$site_root"

    local php_sock
    php_sock=$(get_php_fpm_sock)

    # 先创建 HTTP 虚拟主机
    cat > "${VHOST_DIR}/${domain}.conf" <<VHOST
server {
    listen 80;
    listen [::]:80;
    server_name ${domain};
    root ${site_root};
    index index.html index.htm index.php;

    if (!-e \$request_filename) {
        rewrite ^(.*)\$ /index.php\$1 last;
    }

    location ~ \.php(/|\$) {
        fastcgi_pass unix:${php_sock};
        fastcgi_index index.php;
        fastcgi_split_path_info ^(.+\.php)(/.+)\$;
        set \$path_info \$fastcgi_path_info;
        fastcgi_param PATH_INFO \$path_info;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ^~ /.well-known {
        allow all;
    }

    location ~ /\. {
        deny all;
    }

    access_log ${LOGDIR}/${domain}_access.log;
    error_log  ${LOGDIR}/${domain}_error.log warn;
}
VHOST

    # 创建默认首页
    if [ ! -f "${site_root}/index.html" ] && [ ! -f "${site_root}/index.php" ]; then
        cat > "${site_root}/index.html" <<HTML
<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>${domain}</title></head>
<body><h1>${domain} 站点已就绪</h1></body>
</html>
HTML
        chown www:www "${site_root}/index.html"
    fi

    nginx -t 2>/dev/null
    if [ $? -eq 0 ]; then
        systemctl reload nginx
        print_ok "虚拟主机 ${domain} 创建成功"
        print_info "站点目录: ${site_root}"
    else
        print_error "Nginx 配置有误，请检查"
        nginx -t
    fi

    echo ""
    echo -en "${BOLD}是否立即申请 SSL 证书？[y/N]: ${NC}"
    read -r ssl_choice
    if [[ "$ssl_choice" =~ ^[yY] ]]; then
        ssl_add "$domain"
    fi
}

vhost_del() {
    echo ""
    vhost_list

    echo -en "${BOLD}请输入要删除的域名: ${NC}"
    read -r domain

    if [ -z "$domain" ]; then
        print_error "域名不能为空"
        return 1
    fi

    if [ ! -f "${VHOST_DIR}/${domain}.conf" ]; then
        print_error "虚拟主机 ${domain} 不存在"
        return 1
    fi

    echo -en "${YELLOW}确定要删除 ${domain} 的虚拟主机配置？站点文件不会被删除 [y/N]: ${NC}"
    read -r confirm
    if [[ ! "$confirm" =~ ^[yY] ]]; then
        print_info "操作已取消"
        return 0
    fi

    rm -f "${VHOST_DIR}/${domain}.conf"
    systemctl reload nginx
    print_ok "虚拟主机 ${domain} 已删除"
    print_info "站点文件保留在: ${WEBROOT}/${domain}/"
}

vhost_list() {
    echo ""
    echo -e "${BOLD}虚拟主机列表:${NC}"
    echo ""

    local count=0
    for conf in "${VHOST_DIR}"/*.conf; do
        if [ -f "$conf" ]; then
            local name
            name=$(basename "$conf" .conf)
            local root_dir
            root_dir=$(grep -m1 'root ' "$conf" | awk '{print $2}' | tr -d ';')
            local has_ssl=""
            if grep -q 'ssl_certificate' "$conf" 2>/dev/null; then
                has_ssl=" ${GREEN}[SSL]${NC}"
            fi
            echo -e "  ${CYAN}${name}${NC}${has_ssl}"
            echo -e "    目录: ${root_dir}"
            ((count++))
        fi
    done

    if [ "$count" -eq 0 ]; then
        echo -e "  ${YELLOW}(暂无虚拟主机)${NC}"
    fi
    echo ""
}

# ========================
# SSL 证书管理
# ========================

ssl_add() {
    local domain="${1}"

    if [ -z "$domain" ]; then
        echo -en "${BOLD}请输入域名: ${NC}"
        read -r domain
    fi

    if [ -z "$domain" ]; then
        print_error "域名不能为空"
        return 1
    fi

    if [ ! -f ~/.acme.sh/acme.sh ]; then
        print_error "acme.sh 未安装，请先运行安装脚本"
        return 1
    fi

    local webroot="${WEBROOT}/${domain}"
    if [ ! -d "$webroot" ]; then
        mkdir -p "$webroot"
        chown -R www:www "$webroot"
    fi

    # 确保域名的 HTTP 虚拟主机存在
    if [ ! -f "${VHOST_DIR}/${domain}.conf" ]; then
        print_warn "未找到 ${domain} 的虚拟主机配置，先创建..."
        vhost_add_simple "$domain" "$webroot"
    fi

    print_info "为 ${domain} 申请 SSL 证书..."

    mkdir -p "${webroot}/.well-known/acme-challenge"
    chown -R www:www "$webroot"

    ~/.acme.sh/acme.sh --issue \
        -d "$domain" \
        --webroot "$webroot" \
        --keylength 2048

    if [ $? -ne 0 ]; then
        print_warn "webroot 验证失败，尝试 standalone 方式..."
        systemctl stop nginx
        ~/.acme.sh/acme.sh --issue \
            -d "$domain" \
            --standalone \
            --keylength 2048
        systemctl start nginx
    fi

    local ssl_dir="${SSL_DIR}/${domain}"
    mkdir -p "$ssl_dir"

    ~/.acme.sh/acme.sh --install-cert -d "$domain" \
        --key-file "${ssl_dir}/privkey.pem" \
        --fullchain-file "${ssl_dir}/fullchain.pem" \
        --reloadcmd "systemctl reload nginx"

    if [ $? -eq 0 ]; then
        update_vhost_ssl "$domain"
        print_ok "SSL 证书已申请并配置: ${domain}"
        print_info "证书将自动续期"
    else
        print_error "SSL 证书申请失败，请确认:"
        print_error "  1. 域名已正确解析到本服务器 IP"
        print_error "  2. 80 端口可以从外网访问"
    fi
}

ssl_renew() {
    print_info "续期所有 SSL 证书..."
    if [ -f ~/.acme.sh/acme.sh ]; then
        ~/.acme.sh/acme.sh --renew-all --force
        print_ok "证书续期完成"
    else
        print_error "acme.sh 未安装"
    fi
}

# 不交互地创建简单 HTTP 虚拟主机
vhost_add_simple() {
    local domain="$1"
    local site_root="$2"
    local php_sock
    php_sock=$(get_php_fpm_sock)

    cat > "${VHOST_DIR}/${domain}.conf" <<VHOST
server {
    listen 80;
    listen [::]:80;
    server_name ${domain};
    root ${site_root};
    index index.html index.htm index.php;

    if (!-e \$request_filename) {
        rewrite ^(.*)\$ /index.php\$1 last;
    }

    location ~ \.php(/|\$) {
        fastcgi_pass unix:${php_sock};
        fastcgi_index index.php;
        fastcgi_split_path_info ^(.+\.php)(/.+)\$;
        set \$path_info \$fastcgi_path_info;
        fastcgi_param PATH_INFO \$path_info;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ^~ /.well-known {
        allow all;
    }

    location ~ /\. {
        deny all;
    }

    access_log ${LOGDIR}/${domain}_access.log;
    error_log  ${LOGDIR}/${domain}_error.log warn;
}
VHOST

    systemctl reload nginx
}

update_vhost_ssl() {
    local domain="$1"
    local site_root="${WEBROOT}/${domain}"
    local ssl_dir="${SSL_DIR}/${domain}"
    local php_sock
    php_sock=$(get_php_fpm_sock)

    cat > "${VHOST_DIR}/${domain}.conf" <<VHOST
server {
    listen 80;
    listen [::]:80;
    server_name ${domain};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name ${domain};
    root ${site_root};
    index index.html index.htm index.php;

    ssl_certificate     ${ssl_dir}/fullchain.pem;
    ssl_certificate_key ${ssl_dir}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    if (!-e \$request_filename) {
        rewrite ^(.*)\$ /index.php\$1 last;
    }

    location ~ \.php(/|\$) {
        fastcgi_pass unix:${php_sock};
        fastcgi_index index.php;
        fastcgi_split_path_info ^(.+\.php)(/.+)\$;
        set \$path_info \$fastcgi_path_info;
        fastcgi_param PATH_INFO \$path_info;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ^~ /.well-known {
        allow all;
    }

    location ~ /\. {
        deny all;
    }

    access_log ${LOGDIR}/${domain}_access.log;
    error_log  ${LOGDIR}/${domain}_error.log warn;
}
VHOST

    systemctl reload nginx
}

# ========================
# 信息查看
# ========================

do_info() {
    echo ""
    echo -e "${BOLD}LNMP 安装信息:${NC}"
    echo ""

    if [ -f "$INSTALL_INFO" ]; then
        source "$INSTALL_INFO"
        echo -e "  Nginx:      ${NGINX_VERSION:-$(nginx -v 2>&1 | awk -F/ '{print $2}')}"
        echo -e "  MariaDB:    ${MARIADB_VERSION}"
        echo -e "  PHP:        ${PHP_VERSION}"
        echo -e "  安装时间:   ${INSTALL_DATE}"
        echo -e "  服务器 IP:  ${SERVER_IP}"
        echo ""
        echo -e "  站点目录:   ${WEBROOT}"
        echo -e "  日志目录:   ${LOGDIR}"
        echo -e "  虚拟主机:   ${VHOST_DIR}"
        echo -e "  SSL 证书:   ${SSL_DIR}"
    else
        echo -e "  Nginx:  $(nginx -v 2>&1 | awk -F/ '{print $2}' 2>/dev/null || echo '未安装')"

        local php_ver_file="/usr/local/nginx/conf/.php_version"
        if [ -f "$php_ver_file" ]; then
            echo -e "  PHP:    $(cat "$php_ver_file")"
        else
            echo -e "  PHP:    $(php -v 2>/dev/null | head -1 || echo '未安装')"
        fi

        echo -e "  MariaDB: $(mariadb --version 2>/dev/null || mysql --version 2>/dev/null || echo '未安装')"
    fi
    echo ""
}

# ========================
# PHP 扩展管理
# ========================

php_ext_install() {
    local ext_name="$1"
    local php_ver

    if [ -f /usr/local/nginx/conf/.php_version ]; then
        php_ver=$(cat /usr/local/nginx/conf/.php_version)
    else
        php_ver=$(php -v 2>/dev/null | head -1 | grep -oP '\d+\.\d+' | head -1)
    fi

    if [ -z "$php_ver" ]; then
        print_error "无法检测 PHP 版本"
        return 1
    fi

    if [ -z "$ext_name" ]; then
        echo ""
        echo -e "${BOLD}可安装的常用扩展:${NC}"
        echo ""
        echo -e "  ${CYAN}curl gd mbstring xml zip bcmath intl soap${NC}"
        echo -e "  ${CYAN}redis memcached imagick sqlite3 pgsql${NC}"
        echo -e "  ${CYAN}ldap imap gmp bz2 exif fileinfo sockets xdebug${NC}"
        echo ""
        echo -en "${BOLD}请输入要安装的扩展名 (多个用空格分隔): ${NC}"
        read -r ext_name
    fi

    if [ -z "$ext_name" ]; then
        print_error "扩展名不能为空"
        return 1
    fi

    local php_prefix
    if command -v apt-get &>/dev/null; then
        php_prefix="php${php_ver}"
    else
        php_prefix="php"
    fi

    for ext in $ext_name; do
        local pkg="${php_prefix}-${ext}"
        print_info "安装 ${pkg}..."

        if command -v apt-get &>/dev/null; then
            DEBIAN_FRONTEND=noninteractive apt-get install -y "$pkg"
        elif command -v dnf &>/dev/null; then
            dnf install -y "$pkg"
        elif command -v yum &>/dev/null; then
            yum install -y "$pkg"
        fi

        if [ $? -eq 0 ]; then
            print_ok "${ext} 安装成功"
        else
            print_error "${ext} 安装失败"
        fi
    done

    local fpm_svc
    fpm_svc=$(get_php_fpm_service)
    systemctl restart "$fpm_svc" 2>/dev/null
    print_ok "PHP-FPM 已重启"
}

php_ext_list() {
    local php_bin
    if [ -f /usr/local/nginx/conf/.php_version ]; then
        local php_ver
        php_ver=$(cat /usr/local/nginx/conf/.php_version)
        php_bin="php${php_ver}"
    fi
    if ! command -v "$php_bin" &>/dev/null; then
        php_bin="php"
    fi

    echo ""
    echo -e "${BOLD}已安装的 PHP 扩展:${NC}"
    echo ""
    $php_bin -m 2>/dev/null | grep -v '^\[' | sort | while read -r ext; do
        [ -n "$ext" ] && echo -e "  ${GREEN}*${NC} ${ext}"
    done
    echo ""
}

# ========================
# 使用帮助
# ========================

show_usage() {
    echo ""
    echo -e "${BOLD}LNMP 管理脚本${NC}"
    echo ""
    echo -e "用法: ${CYAN}lnmp <命令>${NC}"
    echo ""
    echo -e "${BOLD}服务管理:${NC}"
    echo -e "  ${CYAN}start${NC}           启动所有服务"
    echo -e "  ${CYAN}stop${NC}            停止所有服务"
    echo -e "  ${CYAN}restart${NC}         重启所有服务"
    echo -e "  ${CYAN}reload${NC}          重载配置 (不中断服务)"
    echo -e "  ${CYAN}status${NC}          查看服务状态"
    echo ""
    echo -e "${BOLD}虚拟主机:${NC}"
    echo -e "  ${CYAN}vhost add${NC}       添加虚拟主机"
    echo -e "  ${CYAN}vhost del${NC}       删除虚拟主机"
    echo -e "  ${CYAN}vhost list${NC}      列出所有虚拟主机"
    echo ""
    echo -e "${BOLD}SSL 证书:${NC}"
    echo -e "  ${CYAN}ssl add [域名]${NC}  申请 SSL 证书"
    echo -e "  ${CYAN}ssl renew${NC}       续期所有证书"
    echo ""
    echo -e "${BOLD}PHP 扩展:${NC}"
    echo -e "  ${CYAN}php ext install [名称]${NC}  安装 PHP 扩展"
    echo -e "  ${CYAN}php ext list${NC}            列出已安装扩展"
    echo ""
    echo -e "${BOLD}其他:${NC}"
    echo -e "  ${CYAN}info${NC}            查看安装信息"
    echo ""
}

# ========================
# 主入口
# ========================

if [[ $EUID -ne 0 ]]; then
    print_error "请使用 root 权限运行 (sudo lnmp $*)"
    exit 1
fi

case "$1" in
    start)    do_start ;;
    stop)     do_stop ;;
    restart)  do_restart ;;
    reload)   do_reload ;;
    status)   do_status ;;
    vhost)
        case "$2" in
            add)  vhost_add ;;
            del)  vhost_del ;;
            list) vhost_list ;;
            *)    print_error "用法: lnmp vhost {add|del|list}" ;;
        esac
        ;;
    ssl)
        case "$2" in
            add)   ssl_add "$3" ;;
            renew) ssl_renew ;;
            *)     print_error "用法: lnmp ssl {add [域名]|renew}" ;;
        esac
        ;;
    php)
        case "$2" in
            ext)
                case "$3" in
                    install) php_ext_install "$4" ;;
                    list)    php_ext_list ;;
                    *)       print_error "用法: lnmp php ext {install [名称]|list}" ;;
                esac
                ;;
            *)  print_error "用法: lnmp php ext {install [名称]|list}" ;;
        esac
        ;;
    info) do_info ;;
    *)    show_usage ;;
esac
